{
  "name": "ffm-cloud-spike",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Phase 0 spike: Cloudflare Worker + R2 + D1 backend validation for Fraxinus Field Mapper",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init:local": "wrangler d1 execute ffm-spike --local --file=schema.sql",
    "db:init:remote": "wrangler d1 execute ffm-spike --remote --file=schema.sql",
    "spike": "node test/spike.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "aws4fetch": "^1.0.20"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250601.0",
    "typescript": "^5.6.3",
    "wrangler": "^3.90.0"
  }
}
